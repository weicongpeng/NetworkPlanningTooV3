 const MAX_ERRORS =5
 
+// PCI范围常量
+const LTE_PCI_RANGE = { min: 0, max: 503 }
+const NR_PCI_RANGE = { min: 0, max: 1007 }
+
+// 验证PCI范围
+function validatePCIRange(min: number, max: number, networkType: 'LTE' | 'NR'): {
+  isValid: boolean
+  error?: string
+  correctedMin?: number
+  correctedMax?: number
+} {
+  const range = networkType === 'LTE' ? LTE_PCI_RANGE : NR_PCI_RANGE
+  
+  if (isNaN(min) || isNaN(max)) {
+    return {
+      isValid: false,
+      error: 'PCI范围必须是有效的数字',
+      correctedMin: range.min,
+      correctedMax: range.max
+    }
+  }
+  
+  if (!Number.isInteger(min) || !Number.isInteger(max)) {
+    return {
+      isValid: false,
+      error: 'PCI范围必须是整数',
+      correctedMin: Math.round(min),
+      correctedMax: Math.round(max)
+    }
+  }
+  
+  if (min < range.min || max > range.max) {
+    return {
+      isValid: false,
+      error: `${networkType}网络PCI范围限制为${range.min}-${range.max}`,
+      correctedMin: Math.max(range.min, Math.min(range.max, min)),
+      correctedMax: Math.min(range.max, Math.max(range.min, max))
+    }
+  }
+  
+  if (min > max) {
+    return {
+      isValid: false,
+      error: 'PCI最小值不能大于最大值',
+      correctedMin: min,
+      correctedMax: Math.max(min, max)
+    }
+  }
+  
+  return { isValid: true }
+}
