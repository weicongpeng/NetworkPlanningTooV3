{
  "appId": "com.networkplanning.tool",
  "productName": "网络规划工具",
  "electronVersion": "28.3.3",
  "copyright": "Copyright © 2024",
  "directories": {
    "output": "release",
    "buildResources": "build"
  },
  "files": [
    "dist-renderer/**/*",
    "dist-electron/**/*",
    "package.json",
    "!node_modules/**/*",
    "node_modules/electron/**/*"
  ],
  "extraResources": [
    {
      "from": "../backend",
      "to": "app.asar.unpacked/backend",
      "filter": [
        "**/*",
        "!venv/**/*",
        "!__pycache__/**/*",
        "!*.pyc",
        "!*.pyo",
        "!.git/**/*",
        "!tests/**/*",
        "!test_*.py",
        "!*.log",
        "!*.tmp",
        "!uploads/**/*",
        "!data/**/*",
        "!outputs/**/*",
        "!exports/**/*",
        "!licenses/**/*",
        "!tmp/**/*",
        "!.env",
        "!.env.local"
      ]
    },
    {
      "from": "../backend/venv",
      "to": "app.asar.unpacked/backend/venv",
      "filter": [
        "Lib/**/*",
        "Scripts/**/*",
        "pyvenv.cfg"
      ]
    }
  ],
  "asar": true,
  "asarUnpack": [
    "**/node_modules/sharp/**/*",
    "**/node_modules/@img/**/*"
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      },
      {
        "target": "portable",
        "arch": ["x64"]
      }
    ],
    "requestedExecutionLevel": "asInvoker",
    "artifactName": "${productName}-${version}-${arch}-${target}.${ext}",
    "sign": null
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "allowElevation": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "网络规划工具",
    "installerLanguages": ["zh_CN", "en_US"],
    "language": "2052",
    "deleteAppDataOnUninstall": false,
    "runAfterFinish": true
  },
  "portable": {
    "artifactName": "${productName}-${version}-便携版.exe"
  },
  "mac": {
    "target": [
      {
        "target": "dmg",
        "arch": ["x64", "arm64"]
      },
      {
        "target": "zip",
        "arch": ["x64", "arm64"]
      }
    ],
    "category": "public.app-category.productivity",
    "hardenedRuntime": true,
    "gatekeeperAssess": false,
    "artifactName": "${productName}-${version}-${arch}-${target}.${ext}"
  },
  "dmg": {
    "contents": [
      {
        "x": 130,
        "y": 220
      },
      {
        "x": 410,
        "y": 220,
        "type": "link",
        "path": "/Applications"
      }
    ],
    "window": {
      "width": 540,
      "height": 380
    }
  },
  "linux": {
    "target": [
      {
        "target": "AppImage",
        "arch": ["x64"]
      },
      {
        "target": "deb",
        "arch": ["x64"]
      }
    ],
    "category": "Utility",
    "maintainer": "Network Planning Tool Team",
    "vendor": "Network Planning Tool Team",
    "synopsis": "电信网络规划工具",
    "description": "用于PCI、邻区、TAC规划和地图可视化的桌面应用",
    "artifactName": "${productName}-${version}-${arch}-${target}.${ext}"
  },
  "publish": {
    "provider": "generic",
    "url": "https://example.com/releases"
  },
  "compression": "maximum",
  "removePackageScripts": true
}
