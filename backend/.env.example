# 网络规划工具后端环境变量配置模板
# 复制此文件为 .env 并填写实际值

# 服务器配置
NPT_HOST=127.0.0.1
NPT_PORT=8000

# 许可证配置（生产环境请使用强密钥）
NPT_LICENSE_SECRET_KEY=network-planning-tool-secret-key-2024
NPT_LICENSE_EXPIRY_DAYS=365

# 高德地图配置
NPT_AMAP_API_KEY=your_amap_api_key_here
NPT_AMAP_SECURITY_CODE=

# CORS配置（生产环境请指定具体域名）
NPT_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 任务配置
NPT_MAX_TASKS=10
NPT_TASK_TIMEOUT=3600
